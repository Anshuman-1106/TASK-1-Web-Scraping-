import requests
from bs4 import BeautifulSoup
import pandas as pd
import time
import logging

# ── Setup Logging ────────────────────────────────────────────────
logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(message)s")

# ── Config ───────────────────────────────────────────────────────
BASE_URL  = "https://books.toscrape.com/catalogue/page-{}.html"
MAX_PAGES = 5
HEADERS   = {"User-Agent": "Mozilla/5.0"}

# ── Scraper Function ─────────────────────────────────────────────
def scrape_page(page_num):
    url      = BASE_URL.format(page_num)
    response = requests.get(url, headers=HEADERS, timeout=10)

    if response.status_code != 200:
        logging.warning(f"Failed to fetch page {page_num}")
        return []

    soup  = BeautifulSoup(response.text, "html.parser")
    books = []

    for book in soup.find_all("article", class_="product_pod"):
        books.append({
            "Title"       : book.find("h3").find("a")["title"],
            "Price"       : book.find("p", class_="price_color").text.strip(),
            "Rating"      : book.find("p", class_="star-rating")["class"][1],
            "Availability": book.find("p", class_="availability").text.strip(),
            "Page"        : page_num
        })
    return books

# ── Main Pipeline ────────────────────────────────────────────────
all_books = []
for page in range(1, MAX_PAGES + 1):
    logging.info(f"Scraping page {page}...")
    all_books.extend(scrape_page(page))
    time.sleep(1.5)  # ✅ Respect server rate limits

# ── Save Dataset ─────────────────────────────────────────────────
df = pd.DataFrame(all_books)
df.drop_duplicates(inplace=True)
df.to_csv("custom_books_dataset.csv", index=False)
logging.info(f"✅ Dataset created: {len(df)} records saved!")
